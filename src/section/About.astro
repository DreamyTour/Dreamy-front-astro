---
import type { About } from "@/interface/home";
import type { Lang } from "@/lib/i18n";

interface Props {
  data?: About;
  lang: Lang;
}

const { data, lang } = Astro.props;
if (!data) return;

const strapiUrl = import.meta.env.VITE_STRAPI_URL?.replace(/\/$/, "");
const imagenUrl = data.imagen?.url ? `${strapiUrl}${data.imagen.url}` : null;
const imageAlt = data.imagen?.alternativeText || data.titulo;
const contentParagraphs = data.content
  .split(/\n+/)
  .map((paragraph) => paragraph.trim())
  .filter(Boolean);

const eyebrowByLang: Record<Lang, string> = {
  en: "Who we are",
  es: "Quiénes somos",
  pt: "Quem somos",
};
---

<section class="w-full border-y border-[#181311]/6 bg-primary/5">
  <div class="mx-auto max-w-8xl px-6 py-16 md:py-20 lg:py-28">
    <div
      class="grid grid-cols-1 items-center gap-12 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] lg:gap-20"
    >
      <div class="w-full max-w-2xl">
        <div
          class="mb-5 inline-flex items-center gap-3 rounded-sm border border-secondary/15 bg-white/80 px-4 py-2 text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-[#181311]/60 shadow-[0_14px_40px_-28px_rgba(24,19,17,0.45)] backdrop-blur-sm"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-secondary"></span>
          <span>{eyebrowByLang[lang]}</span>
        </div>

        <h2
          class="max-w-3xl text-[clamp(2rem,4vw,3.25rem)] font-medium leading-[1.05] text-[#181311]"
        >
          {data.titulo}
        </h2>

        <div
          class="mt-5 h-px w-20 bg-linear-to-r from-secondary/75 via-secondary/25 to-transparent"
        >
        </div>

        <div class="mt-8 space-y-5">
          {
            contentParagraphs.length > 1 ? (
              contentParagraphs.map((paragraph) => (
                <p class="max-w-xl text-base leading-8 text-[#181311]/72">
                  {paragraph}
                </p>
              ))
            ) : (
              <p class="max-w-xl text-base leading-8 text-[#181311]/72">
                {data.content}
              </p>
            )
          }
        </div>

        <div class="mt-10 grid gap-3 sm:grid-cols-3">
          <div
            class="rounded-sm border border-[#181311]/8 bg-white/75 px-4 py-4 shadow-[0_20px_50px_-34px_rgba(24,19,17,0.28)]"
          >
            <p
              class="text-[0.68rem] font-semibold uppercase tracking-[0.26em] text-secondary/80"
            >
              01
            </p>
            <p class="mt-2 text-sm font-medium text-[#181311]/82">
              Atención cercana
            </p>
          </div>
          <div
            class="rounded-sm border border-[#181311]/8 bg-white/75 px-4 py-4 shadow-[0_20px_50px_-34px_rgba(24,19,17,0.28)]"
          >
            <p
              class="text-[0.68rem] font-semibold uppercase tracking-[0.26em] text-secondary/80"
            >
              02
            </p>
            <p class="mt-2 text-sm font-medium text-[#181311]/82">
              Cuidado en los detalles
            </p>
          </div>
          <div
            class="rounded-sm border border-[#181311]/8 bg-white/75 px-4 py-4 shadow-[0_20px_50px_-34px_rgba(24,19,17,0.28)]"
          >
            <p
              class="text-[0.68rem] font-semibold uppercase tracking-[0.26em] text-secondary/80"
            >
              03
            </p>
            <p class="mt-2 text-sm font-medium text-[#181311]/82">
              Experiencia con criterio
            </p>
          </div>
        </div>
      </div>

      {
        data.imagen && (
          <div class="relative w-full">
            <div
              aria-hidden="true"
              class="pointer-events-none absolute inset-4 rounded-sm border border-[#181311]/8 bg-white shadow-[0_30px_100px_-55px_rgba(24,19,17,0.18)] md:inset-6"
            />

            <div class="relative overflow-hidden rounded-sm border border-[#181311]/10 bg-white shadow-[0_28px_80px_-48px_rgba(24,19,17,0.24)]">
              <div class="absolute left-4 top-4 z-10 inline-flex items-center gap-2 rounded-sm border border-white/70 bg-white/88 px-3 py-2 text-[0.65rem] font-semibold uppercase tracking-[0.26em] text-[#181311]/72 shadow-[0_14px_28px_-18px_rgba(24,19,17,0.45)] backdrop-blur-md md:left-5 md:top-5">
                <span class="h-1.5 w-1.5 rounded-full bg-secondary" />
                <span>Dreamy Tours Team</span>
              </div>
              <div class="absolute inset-0 bg-linear-to-t from-[#181311]/10 via-transparent to-transparent" />
              <img
                src={imagenUrl}
                alt={imageAlt}
                class="aspect-[16/9] w-full object-cover object-center"
                loading="lazy"
              />
            </div>
          </div>
        )
      }
    </div>
  </div>
</section>
