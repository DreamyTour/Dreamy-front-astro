---
import type { peruPaquetes } from "@/interface/home";
import type { Tour } from "@/interface/tours";
import type { Lang } from "@/lib/i18n";
import { useTranslations } from "@/i18n/ui";
import fetchApi from "@/lib/strapi";
import ToursSlider from "@/components/ui/ToursSlider.astro";

interface Props {
  data?: peruPaquetes;
  lang: Lang;
}

const { data, lang } = Astro.props;

const t = useTranslations(lang);

if (!data) return;

const strapiUrl = import.meta.env.VITE_STRAPI_URL?.replace(/\/$/, "");

// Fetch tours by category slug
let tours: Tour[] = [];
if (data.category?.slug) {
  const response = await fetchApi<Tour[]>({
    endpoint: "tours",
    wrappedByKey: "data",
    locale: lang,
    query: {
      "filters[categories][slug][$eq]": data.category.slug,
      "pagination[limit]": String(data.limit || 3),
      "populate[imagenDestacada]": "*",
      "populate[badge][populate][icono]": "*",
    },
  });
  tours = response && Array.isArray(response) ? response : [];
}

if (tours.length === 0) return;
---

<section class="w-full py-20 md:py-28">
  <div class="max-w-8xl mx-auto px-6">
    <div class="mb-14 md:mb-20 text-center">
      <h2
        class="text-2xl md:text-3xl font-bold text-gray-900 mb-6 relative inline-block"
      >
        <span class="relative z-10">{data.titulo}</span>
        <span
          class="absolute bottom-0 left-1/2 -translate-x-1/2 w-24 h-3 bg-secondary/30 -z-0 rounded-full blur-sm"
        ></span>
      </h2>
      <div class="flex items-center justify-center gap-3 mt-4">
        <div
          class="h-[1px] w-16 bg-gradient-to-r from-transparent to-secondary"
        >
        </div>
        <div class="w-12 h-1.5 bg-secondary rounded-full relative">
          <div
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-2 h-2 bg-white rounded-full"
          >
          </div>
        </div>
        <div
          class="h-[1px] w-16 bg-gradient-to-l from-transparent to-secondary"
        >
        </div>
      </div>
    </div>

    <ToursSlider tours={tours} lang={lang} />

    {/* Botón ver más */}
    {
      data.category?.slug && (
        <div class="text-center mt-12">
          <a
            href={`/${lang}/${data.category.slug}`}
            aria-label={t("aria.verMasSeccion")}
            class="inline-flex items-center gap-2 px-12 py-5 bg-transparent text-secondary font-bold text-lg rounded-full border-2 border-secondary hover:bg-secondary hover:text-white transition-all duration-300 shadow-xl hover:shadow-2xl transform hover:-translate-y-1"
          >
            {t("section.verMas")}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-6 h-6"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      )
    }
  </div>
</section>
