---
import type { Badge } from "@/interface/tours";
import type { Lang } from "@/lib/i18n";

interface Props {
  badges: Badge[];
  lang: Lang;
}

const { badges } = Astro.props;
if (!badges || badges.length === 0) return;

const strapiUrl = import.meta.env.VITE_STRAPI_URL?.replace(/\/$/, "");
---

<section class="tour-badges w-full py-4 md:py-6 mb-16">
  <div class="overflow-hidden">
    <div
      class="flex flex-col md:flex-row divide-y md:divide-y-0 md:divide-x divide-gray-200/70"
    >
      {
        badges.map((badge, index) => {
          const iconUrl = badge.icono?.url
            ? `${strapiUrl}${badge.icono.url}`
            : null;

          return (
            <div
              class="flex-1 flex items-center justify-start md:justify-center px-6 md:px-4 lg:px-4 py-3 md:py-3 hover:bg-gray-50/50 transition-colors duration-300 group"
              style={`animation: badge-fade-in 0.5s ease-out ${index * 0.1}s both;`}
            >
              <div class="flex items-center gap-4 lg:gap-5 w-full md:w-auto">
                {/* Icono */}
                {iconUrl ? (
                  <div class="flex-shrink-0">
                    <img
                      src={iconUrl}
                      alt={badge.icono?.alternativeText ?? badge.titulo}
                      class="w-6 h-6 object-contain"
                      loading="lazy"
                    />
                  </div>
                ) : (
                  <div class="flex-shrink-0 w-9 h-9 md:w-10 md:h-10 lg:w-11 lg:h-11 flex items-center justify-center">
                    <span class="text-secondary text-xl font-bold">●</span>
                  </div>
                )}

                {/* Texto */}
                <div class="flex flex-col min-w-0">
                  <span class="text-[0.95rem] md:test-base font-bold text-gray-800 leading-tight">
                    {badge.content}
                  </span>
                  <span class="text-[0.65rem] lg:text-[0.7rem] font-medium uppercase tracking-[0.15em] text-gray-400 mt-1">
                    {badge.titulo}
                  </span>
                </div>
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  @keyframes badge-fade-in {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
