---
import type { Tour } from "@/interface/tours";
import type { Lang } from "@/lib/i18n";
import { useTranslations } from "@/i18n/ui";

interface Props {
  tour: Tour;
  lang: Lang;
}

const { tour, lang } = Astro.props;

if (!tour) return null;

const t = useTranslations(lang);

const strapiUrl = import.meta.env.VITE_STRAPI_URL?.replace(/\/$/, "");

const imgObj = Array.isArray(tour.imagenDestacada)
  ? tour.imagenDestacada[0]
  : tour.imagenDestacada;

const mainImage = imgObj?.url ? `${strapiUrl}${imgObj.url}` : null;
const primaryCategory = tour.categories?.[0]?.nombre;
---

<article
  class="group relative flex h-full flex-col overflow-hidden rounded-sm border border-slate-200/80 bg-white transition-all duration-500 hover:-translate-y-1 hover:border-primary/15"
>
  {/* Image Container */}
  <a
    href={`/${lang}/${tour.slug}`}
    tabindex="-1"
    aria-hidden="true"
    class="relative block w-full overflow-hidden border-b border-slate-200/70 aspect-[16/9]"
  >
    {
      mainImage ? (
        <img
          src={mainImage}
          alt={imgObj?.alternativeText ?? tour.titulo}
          class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.035]"
          loading="lazy"
        />
      ) : (
        <div class="flex h-full w-full items-center justify-center bg-slate-100 text-sm font-medium text-slate-400">
          No Image
        </div>
      )
    }
    <div
      class="absolute inset-0 bg-linear-to-t from-slate-950/30 via-slate-950/5 to-transparent opacity-60 transition-opacity duration-300 group-hover:opacity-70"
    >
    </div>
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 h-24 bg-linear-to-t from-black/18 via-black/0 to-transparent"
    >
    </div>
  </a>

  {/* Content Container */}
  <div
    class="relative z-10 flex grow flex-col bg-white px-5 py-5 md:px-6 md:py-6"
  >
    {
      primaryCategory && (
        <div class="mb-2 flex items-center gap-2">
          <span
            aria-hidden="true"
            class="h-px w-6 bg-secondary/55"
          ></span>
          <p class="text-[0.68rem] font-semibold uppercase tracking-[0.22em] text-slate-500">
            {primaryCategory}
          </p>
        </div>
      )
    }
    <h3
      class="mb-3 line-clamp-2 text-[1.26rem] font-semibold leading-[1.15] tracking-[-0.02em] text-slate-950 transition-colors duration-300 group-hover:text-secondary md:text-[1.42rem]"
    >
      <a href={`/${lang}/${tour.slug}`} class="focus:outline-hidden">
        {tour.titulo}
      </a>
    </h3>

    {/* Badges */}
    {
      tour.badge && tour.badge.length > 0 && (
        <div class="mb-5 grid gap-2">
          {tour.badge.slice(0, 3).map((b) => (
            <div class="inline-flex min-w-0 items-center gap-2.5 rounded-sm border border-slate-200/90 bg-slate-50/80 px-3 py-2 text-left transition-colors hover:border-slate-300 hover:bg-white">
              {b.icono?.url ? (
                <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-sm border border-slate-200/80 bg-white">
                  <img
                    src={`${strapiUrl}${b.icono.url}`}
                    alt={b.titulo}
                    class="h-3.5 w-3.5 object-contain opacity-75 grayscale-[0.15]"
                  />
                </div>
              ) : (
                <div class="h-2 w-2 flex-shrink-0 rounded-full bg-primary/45" />
              )}
              <div class="min-w-0 flex-1">
                <p class="mb-0.5 text-[0.62rem] font-semibold uppercase tracking-[0.14em] text-slate-400">
                  {b.titulo}
                </p>
                <p class="line-clamp-1 text-[0.82rem] font-medium text-slate-800">
                  {b.content}
                </p>
              </div>
            </div>
          ))}
        </div>
      )
    }

    <div class="mt-auto pt-1">
      <a
        href={`/${lang}/${tour.slug}`}
        class="group/btn inline-flex w-full items-center justify-between gap-2 rounded-sm border border-primary/15 bg-primary px-4 py-3 text-sm font-semibold text-white transition-all duration-300 hover:-translate-y-0.5 hover:border-primary/30 hover:bg-primary/95 active:scale-[0.995]"
      >
        {t("tour.verItinerario")}
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4 transition-transform duration-300 group-hover/btn:translate-x-1"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
        </svg>
      </a>
    </div>
  </div>
</article>
